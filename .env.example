# Unison brain API key — get one at https://unisonlabs.ai or via:
# curl -X POST https://api.unisonlabs.ai/v1/auth/provision \
#   -H 'Content-Type: application/json' \
#   -d '{"email":"you@example.com"}'
UNISON_TOKEN=usk_live_...

# Override the API base URL (optional — defaults to https://api.unisonlabs.ai)
# Set this when pointing at a self-hosted or local Unison brain.
# UNISON_API_URL=https://api.unisonlabs.ai
